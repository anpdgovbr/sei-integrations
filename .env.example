SONAR_HOST_URL=
SONAR_TOKEN=

SIP_ACCESS_KEY=
SIP_SYSTEM_ID=100000100
SIP_SOAP_ENDPOINT=
SIP_REQUEST_TIMEOUT_MS=30000
SIP_SMOKE_SIGLA_USUARIO=
SIP_SMOKE_DEBUG_SOAP=0
SIP_SMOKE_DEBUG_OPERATION=carregarUsuarios

# Personas de smoke SIP.
# SIP_SMOKE_PERSONA aceita:
# - consulta-completa
# - consulta-vazia
# - sem-servico
SIP_SMOKE_PERSONA=consulta-completa

SIP_PERSONA_CONSULTA_COMPLETA_SYSTEM_ID=100000100
SIP_PERSONA_CONSULTA_COMPLETA_ACCESS_KEY=
SIP_PERSONA_CONSULTA_COMPLETA_SIGLA_USUARIO=
SIP_PERSONA_CONSULTA_COMPLETA_EXPECTED=success

SIP_PERSONA_CONSULTA_VAZIA_SYSTEM_ID=
SIP_PERSONA_CONSULTA_VAZIA_ACCESS_KEY=
SIP_PERSONA_CONSULTA_VAZIA_SIGLA_USUARIO=
SIP_PERSONA_CONSULTA_VAZIA_EXPECTED=empty

SIP_PERSONA_SEM_SERVICO_SYSTEM_ID=
SIP_PERSONA_SEM_SERVICO_ACCESS_KEY=
SIP_PERSONA_SEM_SERVICO_SIGLA_USUARIO=
SIP_PERSONA_SEM_SERVICO_EXPECTED=fault

SEI_SOAP_ENDPOINT=
SEI_SIGLA_SISTEMA=
SEI_IDENTIFICACAO_SERVICO=
SEI_REQUEST_TIMEOUT_MS=30000

# Smoke SEI.
# Ciclo 0: infraestrutura, plano e conferência de configuração.
# Ciclos 1 e 2: leituras automatizadas.
# Ciclos 3 a 8: catalogados; escrita/efeito externo exigirá SEI_SMOKE_ALLOW_WRITE=1
# quando os runners forem ativados.
SEI_SMOKE_CYCLE=1
SEI_SMOKE_OPERATION=
SEI_SMOKE_ALLOW_WRITE=0
SEI_SMOKE_DEBUG_SOAP=0
SEI_SMOKE_DEBUG_OPERATION=

# Base comum para consultas HML.
# Se SEI_SOAP_ENDPOINT ficar vazio e SIP_SOAP_ENDPOINT terminar em /sip/ws/SipWS.php,
# o smoke SEI deriva automaticamente /sei/ws/SeiWS.php no mesmo host.
# Se SEI_SMOKE_SIGLA_USUARIO ficar vazia, o smoke SEI reaproveita
# SIP_SMOKE_SIGLA_USUARIO ou a sigla da persona SIP ativa, quando houver.
SEI_SMOKE_ID_UNIDADE=
SEI_SMOKE_ID_USUARIO=
SEI_SMOKE_SIGLA_USUARIO=
SEI_SMOKE_ID_ORGAO=
SEI_SMOKE_ID_ORGAO_USUARIO=

# Tabelas e filtros de referência.
SEI_SMOKE_ID_TIPO_PROCEDIMENTO=
