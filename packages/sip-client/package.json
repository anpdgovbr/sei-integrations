{
  "name": "@anpdgovbr/sip-client",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "Cliente TypeScript para integração SOAP com o SIP.",
  "keywords": [
    "anpd",
    "sei",
    "sip",
    "soap",
    "typescript"
  ],
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./mappers": {
      "types": "./dist/mappers.d.ts",
      "import": "./dist/mappers.js",
      "require": "./dist/mappers.cjs"
    },
    "./soap": {
      "types": "./dist/soap.d.ts",
      "import": "./dist/soap.js",
      "require": "./dist/soap.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsup && cp README.md LICENSE CHANGELOG.md CONTRIBUTING.md dist/",
    "clean": "rimraf dist coverage",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anpdgovbr/sei-sip-soap": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "rimraf": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.anpd.gov.br"
  },
  "sideEffects": false,
  "author": {
    "name": "Luciano Édipo Pereira da Silva",
    "email": "luciano.psilva@anpd.gov.br",
    "url": "https://github.com/lucianoedipo"
  },
  "bugs": {
    "url": "https://github.com/anpdgovbr/sei-integrations/issues",
    "email": "desenvolvimento@anpd.gov.br"
  },
  "homepage": "https://github.com/anpdgovbr/sei-integrations#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anpdgovbr/sei-integrations.git",
    "directory": "packages/sip-client"
  },
  "typedocOptions": {
    "entryPoints": [
      "src/index.ts",
      "src/mappers.ts"
    ],
    "entryPointStrategy": "resolve",
    "categoryOrder": [
      "Configuração",
      "Cliente",
      "Tratamento de Erros",
      "Transporte SOAP",
      "Entidades de Domínio",
      "Parâmetros de Operação",
      "Replicação",
      "Enumerações",
      "Primitivas SOAP",
      "Mapeadores",
      "*"
    ]
  }
}
