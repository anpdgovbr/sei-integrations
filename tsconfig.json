{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "*.config.js",
    "*.config.ts",
    "eslint.config.js",
    "scripts/**/*.ts",
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts"
  ],
  "exclude": ["node_modules", "**/dist/**", "**/coverage/**", "docs"]
}
