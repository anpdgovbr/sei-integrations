{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "packages",
  "entryPoints": ["packages/sei-sip-soap", "packages/sip-client", "packages/sei-client"],
  "out": "docs",
  "name": "ANPD SEI Integrations",
  "includeVersion": true,
  "readme": "README.md",
  "hideGenerator": true,
  "searchInComments": true,
  "plugin": ["typedoc-plugin-mdn-links"],
  "sourceLinkTemplate": "https://github.com/anpdgovbr/sei-integrations/blob/{gitRevision}/{path}#L{line}",
  "navigationLinks": {
    "GitHub": "https://github.com/anpdgovbr/sei-integrations"
  },
  "groupOrder": ["Classes", "Functions", "Type Aliases", "Interfaces", "Variables", "*"],
  "validation": {
    "invalidLink": true,
    "notExported": true,
    "notDocumented": true
  },
  "treatValidationWarningsAsErrors": true,
  "visibilityFilters": {
    "protected": true,
    "private": false,
    "inherited": true,
    "external": false
  },
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/*.spec.ts",
    "**/*.test.ts",
    "packages/*/test/**"
  ]
}
