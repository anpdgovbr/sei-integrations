{
  "$schema": "https://typedoc.org/schema.json",
  "entryPointStrategy": "packages",
  "entryPoints": ["packages/sei-sip-soap", "packages/sip-client", "packages/sei-client"],
  "out": "docs",
  "name": "ANPD SEI Integrations",
  "includeVersion": true,
  "readme": "README.md",
  "favicon": "assets/brand/logo-196.png",
  "hideGenerator": true,
  "searchInComments": true,
  "highlightLanguages": [
    "bash",
    "console",
    "css",
    "html",
    "javascript",
    "json",
    "jsonc",
    "json5",
    "yaml",
    "tsx",
    "typescript",
    "dotenv"
  ],
  "plugin": ["typedoc-plugin-mdn-links"],
  "sourceLinkTemplate": "https://github.com/anpdgovbr/sei-integrations/blob/{gitRevision}/{path}#L{line}",
  "navigationLinks": {
    "GitHub": "https://github.com/anpdgovbr/sei-integrations"
  },
  "projectDocuments": [
    "doc/sip-client.md",
    "doc/sei-client.md",
    "doc/sip-contrato-wsdl.md",
    "doc/migracao-consumidores.md"
  ],
  "groupOrder": ["Guias", "Classes", "Functions", "Type Aliases", "Interfaces", "Variables", "*"],
  "validation": {
    "invalidLink": true,
    "notExported": true,
    "notDocumented": true
  },
  "treatValidationWarningsAsErrors": true,
  "visibilityFilters": {
    "protected": true,
    "private": false,
    "inherited": true,
    "external": false
  },
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/*.spec.ts",
    "**/*.test.ts",
    "packages/*/test/**"
  ]
}
